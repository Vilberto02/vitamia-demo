# ========================================
# CONFIGURACIÓN DE VITAMIA - BACKEND
# ========================================
# 
# ⚠️ IMPORTANTE: 
# 1. Copia este archivo como .env: cp .env.example .env
# 2. Configura TODAS las variables antes de iniciar el servidor
# 3. NUNCA subas el archivo .env a Git (está en .gitignore)
#
# 📖 Guía completa: ../../SETUP.md
# ========================================

# Base de Datos MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=TU_CONTRASEÑA_MYSQL_AQUI    # ⚠️ Cambia por tu contraseña de MySQL
DB_NAME=vitamia_db
DB_PORT=3306

# Prisma Database URL (actualiza con tu contraseña de MySQL)
DATABASE_URL="mysql://root:TU_CONTRASEÑA_MYSQL_AQUI@localhost:3306/vitamia_db"

# JWT Secret para autenticación (genera un string aleatorio y seguro)
# Puedes generar uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TU_JWT_SECRET_SUPER_SEGURO_AQUI

# Puerto del servidor
PORT=3000

# ========================================
# 🤖 GOOGLE GEMINI API (GRATIS)
# ========================================
# 
# 🔑 Obtén tu API key GRATUITA en:
# https://aistudio.google.com/app/apikey
#
# 1. Haz clic en "Create API key"
# 2. Selecciona "Create API key in new project"
# 3. Copia la key y pégala abajo
#
# ✅ 100% gratuito - 1,500 requests/día
# 📖 Guía detallada: ../../docs/GEMINI_API_SETUP.md
# ========================================

GEMINI_API_KEY=TU_API_KEY_AQUI         # ⚠️ OBLIGATORIO - Pega tu API key de Gemini aquí